generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())

  ownedGroups           Group[]          @relation("GroupOwner")
  memberships           GroupMember[]    @relation("GroupMembership")
  exclusionsAsUserA     GroupExclusion[] @relation("ExclusionA")
  exclusionsAsUserB     GroupExclusion[] @relation("ExclusionB")
  assignmentsAsGiver    Assignment[]     @relation("AssignmentGiver")
  assignmentsAsReceiver Assignment[]     @relation("AssignmentReceiver")
  giftSuggestions       GiftSuggestion[] @relation("GiftSuggestions")
}

model Group {
  id             Int              @id @default(autoincrement())
  name           String
  ownerId        Int
  owner          User             @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members        GroupMember[]
  invite         GroupInvite?
  exclusions     GroupExclusion[]
  assignments    Assignment[]
  suggestions    GiftSuggestion[]
  eventDate      DateTime?
  minGiftCents   Int?
  maxGiftCents   Int?
  eventAddress   String?
  eventLat       Float?
  eventLng       Float?

  @@unique([ownerId, name])
}

model GroupMember {
  id      Int   @id @default(autoincrement())
  groupId Int
  userId  Int
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User  @relation("GroupMembership", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model GroupInvite {
  id        Int      @id @default(autoincrement())
  groupId   Int      @unique
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model GroupExclusion {
  id  Int   @id @default(autoincrement())
  groupId Int
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userAId Int
  userBId Int
  userA User @relation("ExclusionA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("ExclusionB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([groupId, userAId, userBId])
}

model Assignment {
  id         Int       @id @default(autoincrement())
  groupId    Int
  group      Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  giverId    Int
  receiverId Int
  giver      User      @relation("AssignmentGiver", fields: [giverId], references: [id], onDelete: Cascade)
  receiver   User      @relation("AssignmentReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  viewedAt   DateTime?
  createdAt  DateTime  @default(now())

  @@unique([groupId, giverId])
  @@unique([groupId, receiverId])
}

model GiftSuggestion {
  id        Int      @id @default(autoincrement())
  groupId   Int
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation("GiftSuggestions", fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}